# report-triage-agent 환경변수 예시.
#
# docker-compose는 이 파일을 직접 읽지 않는다 (compose의 environment:
# 블록이 우선). 이 파일은 두 가지 용도다.
#   1) 어떤 변수가 필요한지 한 화면으로 보여주기
#   2) 컨테이너 밖에서 직접 앱을 띄울 때 (poetry run / IDE 디버거)
#      `cp .env.example .env` 후 사용
#
# 운영에서는 secret(DB password, NATS token 등)을 이 파일에 두지 말고
# 외부 secret manager에서 주입한다.

# ---- FastAPI ----
APP_HOST=0.0.0.0
APP_PORT=8000

# ---- Postgres (api / worker / consumer 공통) ----
# async 드라이버 사용. compose 안에서는 host=`postgres`,
# 호스트 머신에서 직접 띄울 때는 `localhost`.
DATABASE_URL=postgresql+asyncpg://triage:triage@localhost:5432/triage

# ---- Temporal ----
# compose 안에서는 `temporal:7233`.
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=report-triage

# ---- NATS JetStream ----
# compose 안에서는 `nats://nats:4222`. 단일 stream에 두 subject
# (report.triaged, queue.routed)를 묶는다.
NATS_URL=nats://localhost:4222
NATS_STREAM=report-triage

# ---- frontend (Next.js dev 서버) ----
# 브라우저가 직접 fetch하므로 컨테이너 호스트네임이 아니라 외부 노출 주소.
NEXT_PUBLIC_API_URL=http://localhost:8000
